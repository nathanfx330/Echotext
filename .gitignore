# --- ECHOTEXT CUSTOM IGNORES ---
# Ignore the model directory to protect your custom trained model
/model/*
!/model/.gitkeep

# Ignore the Piper executable/source directories to prevent massive repo bloat
/piper/*
!/piper/.gitkeep

/assets/piper/*
!/assets/piper/.gitkeep

# Ignore ONNX models and JSON configs anywhere in the project just in case
*.onnx
*.onnx.json

# Ignore generated audio files from testing
*.wav
*.mp3